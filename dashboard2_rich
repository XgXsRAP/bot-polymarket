# ── Deterministic BTC market slug calculation (same as bot.py) ──
# No regex scanning needed — we calculate the slug from the clock.
def _calculate_market_slug(asset="btc", window_seconds=300, offset=0):
    """Calculate the deterministic slug for the current market window."""
    import time as _t
    now = int(_t.time())
    window_start = now - (now % window_seconds) + (offset * window_seconds)
    window_label = f"{window_seconds // 60}m"
    return f"{asset}-updown-{window_label}-{window_start}"
