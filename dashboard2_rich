class MarketState:
    def __init__(self):
        self.lock            = threading.Lock()
        self.question        = ""
        self.condition_id    = ""
        self.end_ts          = 0.0
        self.up_bid          = 0.0
        self.up_ask          = 0.0
        self.down_bid        = 0.0
        self.down_ask        = 0.0
        self.price_to_beat   = 0.0
        self.btc_price       = 0.0
        self.last_poly_fetch = 0.0
        self.last_btc_fetch  = 0.0
        self.error           = ""
        self.search_stats    = ""   # e.g. "Scanned: 150 | Matched: 2 | Active: 1"

    def snapshot(self):
        with self.lock:
            return self.__dict__.copy()

_mkt = MarketState()


def _fetch_btc_price():
    try:
        r = requests.get(
            "https://api.binance.com/api/v3/ticker/price",
            params={"symbol": "BTCUSDT"}, timeout=4,
        )
        return float(r.json()["price"])
    except Exception:
        return 0.0


def _fetch_active_market():
    """Find the current BTC 5-min market by calculating the slug directly.

    Instead of scanning 200 markets with regex, we compute the slug from
    the current time: btc-updown-5m-{unix_timestamp} and query for it.
    Falls back to the previous window if the current one isn't indexed yet.
    """
    now = time.time()

    for window_secs in [300, 900]:  # Try 5-min first, then 15-min
        # Try current window
        slug = _calculate_market_slug("btc", window_secs, offset=0)
        market = _fetch_market_by_slug(slug)
        if market:
            with _mkt.lock:
                _mkt.search_stats = f"Found via slug: {slug}"
            return market

        # Fallback: previous window (handles first ~10s of new window)
        prev_slug = _calculate_market_slug("btc", window_secs, offset=-1)
        market = _fetch_market_by_slug(prev_slug)
        if market:
            # Only use if it hasn't expired yet
            try:
                end_ts = datetime.fromisoformat(
                    market.get("endDate", "").replace("Z", "+00:00")
                ).timestamp()
                if end_ts - now > 10:
                    with _mkt.lock:
                        _mkt.search_stats = f"Found via slug: {prev_slug} (prev window)"
                    return market
            except Exception:
                pass

    with _mkt.lock:
        _mkt.search_stats = f"No market found | slug: {_calculate_market_slug('btc', 300)}"
    return None


def _fetch_market_by_slug(slug):
    """Query Gamma API for a specific event slug. Returns the market dict or None."""
    try:
        r = requests.get(
            "https://gamma-api.polymarket.com/events",
            params={"slug": slug},
            timeout=6,
        )
        if r.status_code != 200:
            return None
        events = r.json()
        if not events:
            return None
        event = events[0] if isinstance(events, list) else events
        markets = event.get("markets", [])
        if not markets:
            return None
        return markets[0]
    except Exception:
        return None


def _fetch_clob_orderbook(token_id):
    try:
        r = requests.get(
            "https://clob.polymarket.com/book",
            params={"token_id": token_id}, timeout=4,
        )
        data = r.json()
        bids = data.get("bids", [])
        asks = data.get("asks", [])
        return (float(bids[0]["price"]) if bids else 0.0,
                float(asks[0]["price"]) if asks else 0.0)
    except Exception:
        return 0.0, 0.0


def _data_loop():
    while _running:
        now = time.time()

        if now - _mkt.last_btc_fetch >= 1:
            price = _fetch_btc_price()
            with _mkt.lock:
                if price > 0:
                    _mkt.btc_price      = price
                    _mkt.last_btc_fetch = now
                    if _mkt.price_to_beat == 0.0:
                        _mkt.price_to_beat = price

        if now - _mkt.last_poly_fetch >= 5:
            m = _fetch_active_market()
            if m:
                tokens = m.get("tokens", [])
                up_tok, dn_tok = "", ""
                up_p, dn_p     = 0.0, 0.0
                for tok in tokens:
                    out = tok.get("outcome", "").upper()
                    if out == "YES":
                        up_tok = tok.get("token_id", "")
                        up_p   = float(tok.get("price", 0.5))
                    elif out == "NO":
                        dn_tok = tok.get("token_id", "")
                        dn_p   = float(tok.get("price", 0.5))

                ub, ua = (up_p, up_p)
                db, da = (dn_p, dn_p)
                if up_tok:
                    b, a = _fetch_clob_orderbook(up_tok)
                    if b > 0 or a > 0: ub, ua = b, a
                if dn_tok:
                    b, a = _fetch_clob_orderbook(dn_tok)
                    if b > 0 or a > 0: db, da = b, a

                try:
                    end_ts = datetime.fromisoformat(
                        m.get("endDate", "").replace("Z", "+00:00")
                    ).timestamp()
                except Exception:
                    end_ts = now + 300

                new_cid = m.get("conditionId", "")
                with _mkt.lock:
                    if new_cid != _mkt.condition_id:
                        _mkt.price_to_beat = _mkt.btc_price or 0.0
                    _mkt.condition_id    = new_cid
                    _mkt.question        = m.get("question", "")
                    _mkt.end_ts          = end_ts
                    _mkt.up_bid          = ub
                    _mkt.up_ask          = ua
                    _mkt.down_bid        = db
                    _mkt.down_ask        = da
                    _mkt.last_poly_fetch = now
                    _mkt.error           = ""
            else:
                with _mkt.lock:
                    _mkt.error           = "No active BTC market found"
                    _mkt.last_poly_fetch = now

        time.sleep(0.25)


