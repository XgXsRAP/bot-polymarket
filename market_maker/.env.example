PAPER_TRADING=true
INITIAL_CAPITAL=1000

# Polymarket CLOB credentials (required for live trading only)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=
ALCHEMY_POLYGON_KEY=

# Claude regime analysis (optional)
ANTHROPIC_API_KEY=
CLAUDE_ENABLED=false

# Market price range filter for market maker (optional)
QUOTE_MIN_PRICE=0.0
QUOTE_MAX_PRICE=1.0

# Directional resolver config (--resolver mode)
RESOLVER_MIN_PRICE=0.80   # Only enter when market YES >= this
RESOLVER_MAX_PRICE=0.95   # Only enter when market YES <= this
RESOLVER_MAX_TTE=90       # Only enter when seconds_to_expiry <= this
